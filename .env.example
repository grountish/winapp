# Cloudflare R2 credentials — copy to .env and fill in.
# Dashboard: R2 -> Manage API tokens -> Create token (Object Read & Write)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
# Bucket name (created in R2 dashboard, r2.dev public access enabled)
R2_BUCKET=winapp
# Public URL of the bucket (R2 -> bucket -> Settings -> r2.dev subdomain).
# Set when the player is hosted elsewhere (e.g. Vercel); audio streams from here.
R2_PUBLIC_BASE=https://pub-xxxxxxxxxxxx.r2.dev
